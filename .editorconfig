root = true

[*.{kt,kts}]
ktlint_code_style = android_studio
ktlint_standard_package-name = disabled
ktlint_function_naming_ignore_when_annotated_with = Composable
indent_style = space
indent_size = 4
max_line_length = 100
insert_final_newline = true
trim_trailing_whitespace = true

[*.xml]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2
