root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space

[*.{kt,kts}]
ktlint_code_style = android_studio
ktlint_standard_package-name = disabled
ktlint_function_naming_ignore_when_annotated_with = Composable
indent_size = 4
max_line_length = 100
trim_trailing_whitespace = true

[*.xml]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2
